---
export interface Props {
  data: Array<{ fecha: string; visitantes: number }>;
  title?: string;
}
const { data, title } = Astro.props;
const chartId = "visitor-chart-" + Math.random().toString(36).slice(2, 8);
---

<div class="rounded-xl border border-outline bg-surface-elevated p-6 shadow-sm">
  {title && <h3 class="mb-4 text-lg font-bold text-on-surface">{title}</h3>}
  <div class="relative h-80 w-full">
    <canvas
      id={chartId}
      data-chart-data={JSON.stringify(data)}
      class="visitor-chart h-full w-full"></canvas>
  </div>
</div>

<script>
  import { Chart, registerables } from "chart.js";
  Chart.register(...registerables);

  const canvasElements = document.querySelectorAll(
    ".visitor-chart",
  ) as NodeListOf<HTMLCanvasElement>;

  canvasElements.forEach((canvas) => {
    const rawData = canvas.dataset.chartData;
    if (!rawData) return;

    try {
      const data = JSON.parse(rawData);

      new Chart(canvas, {
        type: "bar",
        data: {
          labels: data.map((d: { fecha: string }) => {
            const date = new Date(d.fecha + "T00:00:00");
            return date.toLocaleDateString("es-MX", {
              day: "numeric",
              month: "short",
            });
          }),
          datasets: [
            {
              type: "line",
              label: "Tendencia de Visitantes",
              data: data.map((d: { visitantes: number }) => d.visitantes),
              borderColor: "#0078a8",
              backgroundColor: "transparent",
              borderWidth: 2,
              tension: 0.4,
              pointBackgroundColor: "#ffffff",
              pointBorderColor: "#0078a8",
              pointBorderWidth: 2,
              pointRadius: 4,
              pointHoverRadius: 6,
              yAxisID: "y",
            },
            {
              type: "bar",
              label: "Visitantes por Día",
              data: data.map((d: { visitantes: number }) => d.visitantes),
              backgroundColor: "rgba(240, 152, 48, 0.35)",
              borderColor: "transparent",
              borderWidth: 0,
              borderRadius: 2,
              barPercentage: 0.7,
              yAxisID: "y",
            },
          ],
        },
        options: {
          responsive: true,
          maintainAspectRatio: false,
          interaction: { mode: "index", intersect: false },
          plugins: {
            legend: {
              position: "top",
              labels: { usePointStyle: true, padding: 20, font: { size: 12 } },
            },
          },
          scales: {
            y: {
              beginAtZero: true,
              grid: { color: "#e3e0dd" },
              ticks: { color: "#797067", font: { size: 11 } },
            },
            x: {
              grid: { display: false },
              ticks: { color: "#797067", font: { size: 11 } },
            },
          },
        },
      });
    } catch (e) {
      console.error("Error parsing visitor chart data:", e);
    }
  });
</script>
