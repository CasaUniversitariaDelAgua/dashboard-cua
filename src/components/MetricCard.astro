---
import Icon from './Icon.astro';

export interface Props {
  title: string;
  value: string | number;
  subtitle?: string;
  icon?: string;
  trend?: 'up' | 'down' | 'neutral';
  trendValue?: string;
}

const { title, value, subtitle, icon, trend, trendValue } = Astro.props;
---

<div class="rounded-xl border border-outline bg-surface-elevated p-6 shadow-sm transition-shadow duration-200 hover:shadow-md">
  <div class="flex items-start justify-between">
    <div class="flex-1">
      <p class="text-sm font-semibold uppercase tracking-wider text-on-surface-muted">{title}</p>
      <p class="mt-2 text-3xl font-bold tracking-tight text-on-surface">{value}</p>
      {subtitle && <p class="mt-1 text-sm text-on-surface-muted">{subtitle}</p>}
      {trend && trendValue && (
        <p class="mt-2 flex items-center gap-1 text-sm font-medium"
          class:list={[trend === 'up' ? 'text-success' : trend === 'down' ? 'text-danger' : 'text-on-surface-muted']}>
          <span>{trend === 'up' ? '↑' : trend === 'down' ? '↓' : '→'}</span>
          <span>{trendValue}</span>
        </p>
      )}
    </div>
    {icon && (
      <div class="flex h-10 w-10 items-center justify-center rounded-lg bg-primary/10 text-primary">
        <Icon name={icon} size={20} />
      </div>
    )}
  </div>
</div>
