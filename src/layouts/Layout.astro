---
import "../styles/global.css";
import Icon from "../components/Icon.astro";
import { Image } from "astro:assets";
import logo from "../assets/icono-favicon.webp";
import type { LayoutProps } from "../lib/types";

const { title, currentPath, user } = Astro.props as LayoutProps;

const navItems = [
  { href: "/", label: "Resumen General", icon: "chart" },
  { href: "/cortes-caja", label: "Cortes de Caja", icon: "cash" },
  { href: "/transacciones", label: "Transacciones", icon: "receipt" },
  { href: "/souvenirs", label: "Souvenirs", icon: "gift" },
  { href: "/visitantes", label: "Visitantes", icon: "users" },
];
---

<!doctype html>
<html lang="es">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{title} | Dashboard CUA</title>
    <link rel="icon" type="image/png" sizes="16x16" href="/favicon-16x16.png" />
    <link rel="icon" type="image/png" sizes="32x32" href="/favicon-32x32.png" />
    <link rel="apple-touch-icon" sizes="180x180" href="/apple-touch-icon.png" />
    <link rel="icon" type="image/png" sizes="192x192" href="/android-chrome-192x192.png" />
    <link rel="icon" type="image/png" sizes="512x512" href="/android-chrome-512x512.png" />
    <link rel="manifest" href="/site.webmanifest" />
    <script is:inline>
      // Initialize desktop sidebar state before rendering to prevent layout flash
      if (localStorage.getItem("sidebar-collapsed") === "true" && window.innerWidth >= 768) {
        document.documentElement.classList.add("init-sidebar-collapsed");
      }
    </script>
  </head>
  <body class="min-h-screen bg-background font-archer text-on-background">
    <div class="flex min-h-screen">
      <!-- Sidebar desktop (collapsible) -->
      <aside
        id="sidebar-desktop"
        class="hidden md:flex md:w-64 md:flex-col md:shrink-0 transition-all duration-300 ease-in-out"
        style="background: rgba(0,0,0,0.70); backdrop-filter: blur(12px); border-right: 1px solid rgba(255,255,255,0.10);"
      >
        <div class="flex h-16 items-center gap-3 px-4 border-b border-white/10 overflow-hidden">
          <div class="shrink-0">
            <Image src={logo} alt="Logo CUA" width={32} height={32} />
          </div>
          <span class="text-sm font-semibold text-on-shell sidebar-text transition-opacity duration-300 whitespace-nowrap">Dashboard CUA</span>
        </div>
        <nav class="flex flex-col gap-1 p-3">
          {
            navItems.map((item) => (
              <a
                href={item.href}
                class="flex items-center gap-3 rounded-md px-3 py-2 text-sm font-semibold transition-colors duration-150 relative group"
                class:list={[
                  currentPath === item.href
                    ? "bg-primary text-on-primary"
                    : "text-white/70 hover:bg-white/10 hover:text-white",
                ]}
              >
                <div class="shrink-0 flex items-center justify-center w-5 h-5">
                  <Icon name={item.icon} size={18} />
                </div>
                <span class="sidebar-text transition-opacity duration-300 whitespace-nowrap">{item.label}</span>
                
                <!-- Tooltip for collapsed state -->
                <span class="sidebar-tooltip absolute left-14 hidden bg-black/90 text-white text-xs px-2.5 py-1.5 rounded-md shadow-md whitespace-nowrap z-50 border border-white/10 pointer-events-none">
                  {item.label}
                </span>
              </a>
            ))
          }
        </nav>
      </aside>

      <!-- Sidebar mobile (fixed overlay) -->
      <aside
        id="sidebar-mobile"
        class="fixed left-0 top-0 z-40 h-full w-64 -translate-x-full transition-transform duration-300 md:hidden"
        style="background: rgba(0,0,0,0.70); backdrop-filter: blur(12px); border-right: 1px solid rgba(255,255,255,0.10);"
      >
        <div class="flex h-16 items-center gap-3 px-4 border-b border-white/10">
          <Image src={logo} alt="Logo CUA" width={28} height={28} />
          <span class="text-sm font-semibold text-on-shell">Dashboard CUA</span>
        </div>
        <nav class="flex flex-col gap-1 p-3">
          {
            navItems.map((item) => (
              <a
                href={item.href}
                class="flex items-center gap-3 rounded-md px-3 py-2 text-sm font-semibold transition-colors duration-150"
                class:list={[
                  currentPath === item.href
                    ? "bg-primary text-on-primary"
                    : "text-white/70 hover:bg-white/10 hover:text-white",
                ]}
              >
                <Icon name={item.icon} size={18} />
                <span>{item.label}</span>
              </a>
            ))
          }
        </nav>
      </aside>

      <!-- Overlay for mobile -->
      <div
        id="sidebar-overlay"
        class="fixed inset-0 z-30 bg-black/50 opacity-0 pointer-events-none transition-opacity duration-300 md:hidden"
      >
      </div>

      <!-- Main content -->
      <div class="flex flex-1 flex-col min-w-0">
        <header
          class="sticky top-0 z-20 flex h-16 items-center gap-4 px-6"
          style="background: rgba(0,0,0,0.70); backdrop-filter: blur(12px); border-bottom: 1px solid rgba(255,255,255,0.10);"
        >
          <button
            id="menu-toggle"
            class="flex h-10 w-10 items-center justify-center rounded-md text-white/70 hover:bg-white/10 hover:text-white cursor-pointer"
          >
            <Icon name="menu" size={20} />
          </button>
          <div class="ml-auto flex items-center gap-3">
            {
              user && (
                <span class="text-xs font-medium text-white/60">
                  {user.nombre}
                </span>
              )
            }
            <a
              href="/logout"
              class="rounded-md bg-white/10 px-3 py-1.5 text-xs font-semibold text-white/70 transition-colors hover:bg-white/20 hover:text-white"
              >Salir</a
            >
          </div>
        </header>

        <main class="flex-1 p-4 md:p-6 lg:p-8 overflow-x-hidden">
          <slot />
        </main>
      </div>
    </div>

    <script>
      const toggle = document.getElementById("menu-toggle");
      const sidebarMobile = document.getElementById("sidebar-mobile");
      const sidebarDesktop = document.getElementById("sidebar-desktop");
      const overlay = document.getElementById("sidebar-overlay");

      // Sync state on page load if initialized before render
      if (sidebarDesktop && document.documentElement.classList.contains("init-sidebar-collapsed")) {
        sidebarDesktop.classList.add("collapsed");
      }

      if (toggle) {
        toggle.addEventListener("click", () => {
          const isMobile = window.innerWidth < 768;

          if (isMobile) {
            if (sidebarMobile && overlay) {
              const isOpen = !sidebarMobile.classList.contains("-translate-x-full");
              sidebarMobile.classList.toggle("-translate-x-full", isOpen);
              overlay.classList.toggle("opacity-0", isOpen);
              overlay.classList.toggle("pointer-events-none", isOpen);
              document.body.classList.toggle("overflow-hidden", !isOpen);
            }
          } else {
            if (sidebarDesktop) {
              // Clear init class to let dynamic class take over
              document.documentElement.classList.remove("init-sidebar-collapsed");
              const isCollapsed = sidebarDesktop.classList.toggle("collapsed");
              localStorage.setItem("sidebar-collapsed", isCollapsed ? "true" : "false");
            }
          }
        });
      }

      if (overlay && sidebarMobile) {
        overlay.addEventListener("click", () => {
          sidebarMobile.classList.add("-translate-x-full");
          overlay.classList.add("opacity-0", "pointer-events-none");
          document.body.classList.remove("overflow-hidden");
        });
      }
    </script>

    <style is:global>
      /* Collapsed desktop sidebar styling rules */
      #sidebar-desktop.collapsed {
        width: 4rem !important; /* 64px (w-16) */
      }
      #sidebar-desktop.collapsed .sidebar-text {
        display: none !important;
      }
      #sidebar-desktop.collapsed .px-4 {
        padding-left: 1rem !important;
        padding-right: 1rem !important;
      }
      #sidebar-desktop.collapsed nav {
        padding-left: 0.5rem !important;
        padding-right: 0.5rem !important;
        align-items: center !important;
      }
      #sidebar-desktop.collapsed nav a {
        justify-content: center !important;
        width: 2.5rem !important;
        height: 2.5rem !important;
        padding: 0 !important;
      }
      
      /* Tooltip visibility rule in collapsed state */
      .sidebar-tooltip {
        display: none;
      }
      #sidebar-desktop.collapsed .sidebar-tooltip {
        display: none;
      }
      /* Show tooltip on hover only when collapsed */
      #sidebar-desktop.collapsed nav a:hover .sidebar-tooltip {
        display: block !important;
      }

      /* Pre-render styles to avoid Layout Shift */
      .init-sidebar-collapsed #sidebar-desktop {
        width: 4rem !important;
      }
      .init-sidebar-collapsed #sidebar-desktop .sidebar-text {
        display: none !important;
      }
      .init-sidebar-collapsed #sidebar-desktop .px-4 {
        padding-left: 1rem !important;
        padding-right: 1rem !important;
      }
      .init-sidebar-collapsed #sidebar-desktop nav {
        padding-left: 0.5rem !important;
        padding-right: 0.5rem !important;
        align-items: center !important;
      }
      .init-sidebar-collapsed #sidebar-desktop nav a {
        justify-content: center !important;
        width: 2.5rem !important;
        height: 2.5rem !important;
        padding: 0 !important;
      }
    </style>
  </body>
</html>
