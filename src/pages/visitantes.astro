---
import Layout from "../layouts/Layout.astro";
import MetricCard from "../components/MetricCard.astro";
import FilterBar from "../components/FilterBar.astro";
import { getTotalVisitantes, getVentasPorDia } from "../lib/queries";
import { getFilters } from "../lib/filters";

const filters = getFilters(Astro.url);
const mes = filters.mes || "todos";
const año = filters.año || "todos";

const visitantes = await getTotalVisitantes({ mes, año });
const ventasPorDia = await getVentasPorDia({ mes, año });

const añoUso = new Date().getFullYear();
const tituloPeriodo =
  mes === "todos" || año === "todos"
    ? "Histórico"
    : new Date(parseInt(año), parseInt(mes) - 1).toLocaleString("es-MX", {
        month: "long",
        year: "numeric",
      });
---

<Layout title="Visitantes" currentPath="/visitantes" user={Astro.locals.user}>
  <div class="space-y-6">
    <div>
      <h1 class="text-2xl font-bold text-on-surface">Total de Visitantes</h1>
      <p class="text-sm text-on-surface-muted">
        Métrica de afluencia basada en boletos de entrada
      </p>
    </div>

    <form method="GET" action="/visitantes">
      <FilterBar
        basePath="/visitantes"
        filters={[
          {
            label: "Mes",
            name: "mes",
            type: "select",
            value: mes,
            options: [
              { value: "todos", label: "Todos" },
              ...Array.from({ length: 12 }, (_, i) => ({
                value: String(i + 1),
                label: new Date(2024, i).toLocaleString("es-MX", {
                  month: "long",
                }),
              })),
            ],
          },
          {
            label: "Año",
            name: "año",
            type: "select",
            value: año,
            options: [
              { value: "todos", label: "Todos" },
              ...[añoUso - 1, añoUso, añoUso + 1].map((a) => ({
                value: String(a),
                label: String(a),
              })),
            ],
          },
        ]}
      />
    </form>

    <div class="grid grid-cols-1 gap-4 sm:grid-cols-2 lg:grid-cols-4">
      <MetricCard
        title="Total Acumulado"
        value={visitantes.visitantes_acumulado}
        icon="users"
        subtitle="Histórico de boletos vendidos"
      />
      <MetricCard
        title={mes === "todos" && año === "todos"
          ? "Visitantes Totales"
          : "Visitantes del Período"}
        value={visitantes.visitantes_mes}
        icon="calendar"
        subtitle={mes === "todos" && año === "todos"
          ? "Boletos en todo el histórico"
          : "Boletos en el período"}
      />
      <MetricCard
        title="Visitantes Hoy"
        value={visitantes.visitantes_hoy}
        icon="users"
        subtitle="Boletos vendidos hoy"
      />
      <MetricCard
        title="Promedio por Día"
        value={visitantes.promedio_por_dia}
        icon="chart"
        subtitle="Visitantes / día activo"
      />
    </div>

    <div
      class="rounded-xl border border-outline bg-surface-elevated p-6 shadow-sm"
    >
      <h3 class="mb-4 text-lg font-bold text-on-surface">
        Actividad Diaria ({tituloPeriodo})
      </h3>
      {
        ventasPorDia.length > 0 ? (
          <div class="space-y-2">
            {ventasPorDia.map((dia) => {
              const maxVisitantes = Math.max(
                ...ventasPorDia.map((d) => d.visitantes ?? 0),
              );
              const porcentaje =
                maxVisitantes > 0
                  ? ((dia.visitantes ?? 0) / maxVisitantes) * 100
                  : 0;
              return (
                <div class="flex items-center gap-3">
                  <span class="w-24 text-xs font-medium text-on-surface-muted shrink-0">
                    {dia.fecha.split("-").slice(1).join("/")}
                  </span>
                  <div
                    class="flex-1 h-6 rounded-md overflow-hidden"
                    style="background-color: rgba(254, 110, 0, 0.08);"
                  >
                    <div
                      class="h-full rounded-md flex items-center justify-end px-2 text-xs font-semibold text-white transition-all duration-300"
                      style={`background-color: #fe6e00; width: ${porcentaje}%; opacity: ${0.3 + (porcentaje / 100) * 0.7};`}
                    >
                      {porcentaje > 15 && <span>{dia.visitantes ?? 0}</span>}
                    </div>
                  </div>
                  <span class="w-16 text-right text-xs font-semibold text-on-surface shrink-0">
                    {dia.visitantes ?? 0}
                  </span>
                </div>
              );
            })}
          </div>
        ) : (
          <p class="text-center text-on-surface-muted py-8">
            No hay datos de actividad para este período
          </p>
        )
      }
    </div>
  </div>
</Layout>
